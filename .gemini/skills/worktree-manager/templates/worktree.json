{
  "$comment": "Optional project-specific worktree-manager config. Copy this template to <project-root>/.claude/worktree.json and customize for your project.",
  "ports": {
    "count": 2,
    "services": [
      "api",
      "frontend"
    ]
  },
  "install": "uv sync",
  "validate": {
    "start": "PORT={{PORT}} docker compose up -d",
    "healthCheck": "curl -sf http://localhost:{{PORT}}/health",
    "healthCheckTimeout": 30,
    "stop": "docker compose down"
  },
  "copyDirs": [
    ".agents",
    ".env.example"
  ],
  "preBranch": null,
  "postCreate": null
}
