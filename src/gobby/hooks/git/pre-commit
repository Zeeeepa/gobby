#!/bin/sh
# Gobby Task & Memory Auto-Sync Hook (pre-commit)
# Exports tasks and memories to JSONL and stages them before commit

# Skip sync for spawned agents — they work in worktrees and should not
# export JSONL back to avoid merge conflicts and data contamination.
if [ -n "$GOBBY_AGENT_RUN_ID" ]; then
    exit 0
fi

if command -v gobby >/dev/null 2>&1; then
    gobby tasks sync --export --quiet 2>/dev/null || true
    gobby memory backup --quiet 2>/dev/null || true

    # Stage the exported files if they exist
    for f in .gobby/tasks.jsonl .gobby/memories.jsonl; do
        [ -f "$f" ] && git add "$f" 2>/dev/null || true
    done
fi
