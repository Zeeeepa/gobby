#!/bin/sh
# Gobby pre-push hook
# Exports tasks and memories to JSONL and amends the tip commit before push.

# Skip for spawned agents to avoid JSONL contamination in worktrees
if [ -n "$GOBBY_AGENT_RUN_ID" ]; then
    exit 0
fi

# Skip for branch deletions (no code being pushed)
DELETE_ONLY=true
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
        DELETE_ONLY=false
        break
    fi
done
if [ "$DELETE_ONLY" = true ]; then
    exit 0
fi

# Export tasks and memories, amend tip commit if JSONL files changed
if command -v gobby >/dev/null 2>&1; then
    gobby tasks sync --export --quiet 2>/dev/null || true
    gobby memory backup --quiet 2>/dev/null || true

    JSONL_CHANGED=false
    for f in .gobby/tasks.jsonl .gobby/memories.jsonl; do
        if [ -f "$f" ] && ! git diff --quiet -- "$f" 2>/dev/null; then
            git add "$f" 2>/dev/null || true
            JSONL_CHANGED=true
        fi
    done

    if [ "$JSONL_CHANGED" = true ]; then
        git commit --amend --no-edit --no-verify 2>/dev/null || true
    fi
fi
